<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_wallet_gradient">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:id="@+id/llInvoiceForm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Retailer POS"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="16dp"
                android:text="NFC payment request, encrypted APDU, server authorization and attack simulation console"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_dark"
                android:elevation="8dp"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Create Bill"
                    android:textColor="@color/text_primary"
                    android:textSize="19sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Kategori"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spItemType"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_card_light"
                    android:padding="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Ürün"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spItemName"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="10dp"
                    android:background="@drawable/bg_card_light"
                    android:padding="12dp" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Tutar"
                    android:textColor="@color/text_secondary"
                    android:textStyle="bold" />

                <EditText
                    android:id="@+id/etAmount"
                    android:layout_width="match_parent"
                    android:layout_height="68dp"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="16dp"
                    android:background="@drawable/bg_input_dark"
                    android:gravity="center"
                    android:hint="0.00"
                    android:inputType="numberDecimal"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/muted"
                    android:textSize="24sp" />

                <Button
                    android:id="@+id/btnReadyToScan"
                    android:layout_width="match_parent"
                    android:layout_height="62dp"
                    android:background="@drawable/bg_button_primary"
                    android:text="ÖDEME AL  •  NFC"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/bg_card_dark"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Security Tools"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:layout_marginBottom="12dp"
                    android:text="Bu butonlar rapor ve sunum için replay ve MITM/tamper senaryolarını kontrollü üretir."
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp" />

                <Button
                    android:id="@+id/btnPosReceipts"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginBottom="9dp"
                    android:background="@drawable/bg_button_success"
                    android:text="RECEIPT GEÇMİŞİ"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnTamperTest"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:layout_marginBottom="9dp"
                    android:background="@drawable/bg_button_purple"
                    android:text="TEST: MITM / TAMPER PAYLOAD"
                    android:textColor="@color/white"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/btnReplayLast"
                    android:layout_width="match_parent"
                    android:layout_height="54dp"
                    android:background="@drawable/bg_button_warning"
                    android:text="TEST: SON İŞLEMİ REPLAY GÖNDER"
                    android:textColor="@color/white"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/tvPosError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_status_red"
                android:gravity="center"
                android:padding="12dp"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/llNfcScanner"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_wallet_gradient"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        android:visibility="gone">

        <TextView
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:background="@drawable/bg_nfc_circle"
            android:gravity="center"
            android:text="NFC"
            android:textColor="@color/white"
            android:textSize="25sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:gravity="center"
            android:text="ÖDEME BEKLENİYOR"
            android:textColor="@color/warning_yellow"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvAmountToPay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:textColor="@color/text_primary"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="18dp"
            android:background="@drawable/bg_status_blue"
            android:gravity="center"
            android:padding="14dp"
            android:text="Müşteri cihazını yaklaştırın. APDU request/response süreleri server console’a loglanır."
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/tvReceipt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:background="@drawable/bg_card_dark"
            android:gravity="center"
            android:padding="18dp"
            android:textColor="@color/accent_green"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnNewTransaction"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="@drawable/bg_button_danger"
            android:text="YENİ İŞLEM / İPTAL"
            android:textColor="@color/white"
            android:textStyle="bold" />
    </LinearLayout>
</FrameLayout>
